rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - id: string (required)
    //   - username: string (required)
    //   - role: string (required, 'admin' | 'user')
    //   - depot: string (optional)
    //   - fullName: string (optional)
    //   - email: string (optional)
    //   - phone: string (optional)
    //   - joinedDate: string (optional)
    //
    // Collection: maintenance_jobs
    // Collection: scheduled_maintenance
    // Collection: staff
    // Collection: attendance
    // Collection: comments
    // Collection: buses
    // Collection: breakdowns
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "mrima.mridul@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['username', 'role']) &&
             data.role in ['admin', 'user'] &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50;
    }

    function isValidMaintenanceJob(data) {
      return hasRequiredFields(['busNumber', 'depot', 'date', 'status', 'createdAt']) &&
             data.status in ['Pending', 'In Progress', 'Completed'];
    }

    function isValidScheduledMaintenance(data) {
      return hasRequiredFields(['busNumber', 'depot', 'scheduledDate', 'status', 'createdAt']) &&
             data.status in ['Scheduled', 'Completed', 'Missed'];
    }

    function isValidStaff(data) {
      return hasRequiredFields(['name', 'designation', 'depot', 'createdAt']);
    }

    function isValidAttendance(data) {
      return hasRequiredFields(['staffId', 'date', 'shift', 'status']) &&
             data.status in ['Present', 'Absent', 'Leave'];
    }

    function isValidComment(data) {
      return hasRequiredFields(['userId', 'username', 'depot', 'text', 'createdAt']) &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000;
    }

    function isValidBus(data) {
      return hasRequiredFields(['busNumber', 'depot', 'createdAt']);
    }

    function isValidBreakdown(data) {
      return hasRequiredFields(['busNumber', 'depot', 'date', 'createdAt']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /maintenance_jobs/{jobId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMaintenanceJob(request.resource.data);
      allow update: if isAuthenticated() && isValidMaintenanceJob(request.resource.data);
      allow delete: if isAdmin();
    }

    match /scheduled_maintenance/{scheduleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidScheduledMaintenance(request.resource.data);
      allow update: if isAuthenticated() && isValidScheduledMaintenance(request.resource.data);
      allow delete: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidStaff(request.resource.data);
      allow update: if isAuthenticated() && isValidStaff(request.resource.data);
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAttendance(request.resource.data);
      allow update: if isAuthenticated() && isValidAttendance(request.resource.data);
      allow delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow update: if isAuthenticated() && isValidComment(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /buses/{busId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBus(request.resource.data);
      allow update: if isAuthenticated() && isValidBus(request.resource.data);
      allow delete: if isAdmin();
    }

    match /breakdowns/{breakdownId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBreakdown(request.resource.data);
      allow update: if isAuthenticated() && isValidBreakdown(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
